{% liquid
  assign display = false
  case block.settings.display
    when 'globally'
      assign display = true
    when 'specific_products'
      assign target_handles = block.settings.display_product_list | map: 'handle'
      if target_handles contains product.handle
        assign display = true
      endif
    when 'products_in_cart'
      assign target_handles = block.settings.display_product_list | map: 'handle'
      for item in cart.items
        if target_handles contains item.product.handle
          assign display = true
          break
        endif
      endfor
    when 'products_not_in_cart'
      assign display = true
      assign target_handles = block.settings.display_product_list | map: 'handle'
      for item in cart.items
        if target_handles contains item.product.handle
          assign display = false
          break
        endif
      endfor
    when 'subtotal_less_than'
      assign threshold = block.settings.display_subtotal_amount | times: 100
      if cart.total_price < threshold
        assign display = true
      endif
    when 'subtotal_more_than'
      assign threshold = block.settings.display_subtotal_amount | times: 100
      if cart.total_price > threshold
        assign display = true
      endif
    when 'specific_page'
      if block.settings.display_page_link != blank and request.path == block.settings.display_page_link
        assign display = true
      endif
  endcase
%}
{% if display %}
  {% render 'upsell-block', block: block, type: 'cart-drawer' %}
{% endif %}

