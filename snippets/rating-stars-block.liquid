{%- liquid
  assign rs_width = block.settings.width | default: 'full'
  assign rs_alignment = block.settings.alignment | default: 'flex-start'
  assign rs_bg_type = block.settings.bg_type | default: 'none'
  assign rs_border_thickness = block.settings.border_thickness | default: 0
  assign rs_enable_shadow = block.settings.enable_shadow | default: false
  assign rs_has_styling = false
  if rs_bg_type != 'none' or rs_border_thickness > 0 or rs_enable_shadow
    assign rs_has_styling = true
  endif

  assign rs_width_css = '100%'
  assign rs_ml = '0'
  assign rs_mr = '0'
  if rs_width == 'fit_content'
    assign rs_width_css = 'fit-content'
    case rs_alignment
      when 'flex-start'
        assign rs_ml = '0'
        assign rs_mr = 'auto'
      when 'center'
        assign rs_ml = 'auto'
        assign rs_mr = 'auto'
      when 'flex-end'
        assign rs_ml = 'auto'
        assign rs_mr = '0'
    endcase
  endif

  assign rs_bg_css = 'none'
  if rs_bg_type == 'solid'
    assign rs_red = block.settings.bg_color | color_extract: 'red'
    assign rs_green = block.settings.bg_color | color_extract: 'green'
    assign rs_blue = block.settings.bg_color | color_extract: 'blue'
    assign rs_bg_alpha = block.settings.bg_opacity | divided_by: 100.0
    assign rs_bg_css = 'rgba(' | append: rs_red | append: ',' | append: rs_green | append: ',' | append: rs_blue | append: ',' | append: rs_bg_alpha | append: ')'
  elsif rs_bg_type == 'gradient'
    assign rs_bg_css = block.settings.bg_gradient
  endif

  assign rs_box_shadow_css = 'none'
  if rs_enable_shadow
    assign rs_shadow_alpha = block.settings.shadow_opacity | divided_by: 100.0
    assign rs_shadow_color = block.settings.shadow_color | color_modify: 'alpha', rs_shadow_alpha
    assign rs_box_shadow_css = block.settings.shadow_horizontal_offset | append: 'px ' | append: block.settings.shadow_vertical_offset | append: 'px ' | append: block.settings.shadow_blur | append: 'px ' | append: block.settings.shadow_spread | append: 'px ' | append: rs_shadow_color
  endif

  assign rs_padding_css = '0'
  assign rs_padding_y_px = 0
  if rs_has_styling
    assign rs_padding_css = '0.6rem 1.1rem'
    assign rs_padding_y_px = 6
  endif

  assign rs_font_size_px = block.settings.size | default: 16
  assign rs_total_height_px = rs_font_size_px | plus: rs_padding_y_px | plus: rs_border_thickness
  assign rs_corner_radius_pct = block.settings.corner_radius | default: 0
  assign rs_radius_rem = rs_total_height_px | times: rs_corner_radius_pct | divided_by: 1000.0
-%}
<div
  class="rating-stars {{ block.settings.visibility }}"
  style='
    --rating:{{ block.settings.rating }};
    --visible-stars:{{ block.settings.rating | ceil }};
    --star-color:{{ block.settings.star_color }};
    --bg-star-color:{{ block.settings.bg_star_color }};
    --font-size:{{ block.settings.size | divided_by: 10.0 }}rem;
    --alignment:{{ rs_alignment }};
    width: {{ rs_width_css }};
    margin-left: {{ rs_ml }};
    margin-right: {{ rs_mr }};
    background: {{ rs_bg_css }};
    {% if rs_border_thickness > 0 %}
      border: {{ rs_border_thickness }}px {{ block.settings.border_style | default: 'solid' }} {{ block.settings.border_color }};
    {% endif %}
    box-shadow: {{ rs_box_shadow_css }};
    border-radius: {{ rs_radius_rem }}rem;
    padding: {{ rs_padding_css }};
    {% if margins %}
      margin-top: {{ block.settings.margin_top | divided_by: 10.0 }}rem;
      margin-bottom: {{ block.settings.margin_bottom | divided_by: 10.0 }}rem;
    {% endif %}
  '
  {% if block_attributes %}
    {{ block.shopify_attributes }}
  {% endif %}
>
  {% if block.settings.scroll_id != blank %}<a href="{{ block.settings.scroll_id }}">{% endif %}
    <div class='rating-stars-and-text font-size--desktop-auto flex-center'>
      <div class='rating-stars__container rating-stars__container--underlay'>
        {% if block.settings.bg_stars_style == 'outlined' %}
          {% for i in (1..5) %}
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 576 512" fill='currentColor'>
              <path d="M287.9 0c9.2 0 17.6 5.2 21.6 13.5l68.6 141.3 153.2 22.6c9 1.3 16.5 7.6 19.3 16.3s.5 18.1-5.9 24.5L433.6 328.4l26.2 155.6c1.5 9-2.2 18.1-9.6 23.5s-17.3 6-25.3 1.7l-137-73.2L151 509.1c-8.1 4.3-17.9 3.7-25.3-1.7s-11.2-14.5-9.7-23.5l26.2-155.6L31.1 218.2c-6.5-6.4-8.7-15.9-5.9-24.5s10.3-14.9 19.3-16.3l153.2-22.6L266.3 13.5C270.4 5.2 278.7 0 287.9 0zm0 79L235.4 187.2c-3.5 7.1-10.2 12.1-18.1 13.3L99 217.9 184.9 303c5.5 5.5 8.1 13.3 6.8 21L171.4 443.7l105.2-56.2c7.1-3.8 15.6-3.8 22.6 0l105.2 56.2L384.2 324.1c-1.3-7.7 1.2-15.5 6.8-21l85.9-85.1L358.6 200.5c-7.8-1.2-14.6-6.1-18.1-13.3L287.9 79z"/>
            </svg>
          {% endfor %}
        {% else %}
          {% for i in (1..5) %}
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 576 512" fill='currentColor'>
              <path d="M316.9 18C311.6 7 300.4 0 288.1 0s-23.4 7-28.8 18L195 150.3 51.4 171.5c-12 1.8-22 10.2-25.7 21.7s-.7 24.2 7.9 32.7L137.8 329 113.2 474.7c-2 12 3 24.2 12.9 31.3s23 8 33.8 2.3l128.3-68.5 128.3 68.5c10.8 5.7 23.9 4.9 33.8-2.3s14.9-19.3 12.9-31.3L438.5 329 542.7 225.9c8.6-8.5 11.7-21.2 7.9-32.7s-13.7-19.9-25.7-21.7L381.2 150.3 316.9 18z"/>
            </svg>
          {% endfor %}
        {% endif %}
        <div class='rating-stars__container rating-stars__container--overlay'>
          {% for i in (1..5) %}
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 576 512" fill='currentColor'>
              <path d="M316.9 18C311.6 7 300.4 0 288.1 0s-23.4 7-28.8 18L195 150.3 51.4 171.5c-12 1.8-22 10.2-25.7 21.7s-.7 24.2 7.9 32.7L137.8 329 113.2 474.7c-2 12 3 24.2 12.9 31.3s23 8 33.8 2.3l128.3-68.5 128.3 68.5c10.8 5.7 23.9 4.9 33.8-2.3s14.9-19.3 12.9-31.3L438.5 329 542.7 225.9c8.6-8.5 11.7-21.2 7.9-32.7s-13.7-19.9-25.7-21.7L381.2 150.3 316.9 18z"/>
            </svg>
          {% endfor %}
        </div>
      </div>
      <span class="rating-stars__label">&nbsp;{{ block.settings.label }}</span>
    </div>
  {% if block.settings.scroll_id != blank %}</a>{% endif %}
</div>
