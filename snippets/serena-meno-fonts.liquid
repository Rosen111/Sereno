{%- comment -%}
  Loads the Serena Meno design fonts (Marcellus, Cormorant Garamond, Mulish).
  Rendered by each serena-* section. Duplicate <link> tags to the same href are
  de-duplicated by the browser, so it is safe to render this more than once.
{%- endcomment -%}
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Marcellus&family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;1,500&family=Mulish:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
{{ 'serena-meno.css' | asset_url | stylesheet_tag }}
