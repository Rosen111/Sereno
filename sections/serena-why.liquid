{%- comment -%} Serena Meno · 3. Why Serena Meno (trust) {%- endcomment -%}
{% render 'serena-meno-fonts' %}
{%- assign s = section.settings -%}
<div
  id="serena-why-{{ section.id }}"
  class="serena-sec serena-why"
  style="--bg: {{ s.bg_color }}; --eyebrow: {{ s.eyebrow_color }}; --card-bg: {{ s.card_bg }}; --card-border: {{ s.card_border }}; --ring-bg: {{ s.ring_bg }}; --ring: {{ s.ring_color }}; --pt: {{ s.padding_top }}px; --pb: {{ s.padding_bottom }}px;"
>
  <div class="serena-wrap">
    <div class="serena-head">
      {%- if s.eyebrow != blank -%}<div class="serena-eyebrow">{{ s.eyebrow }}</div>{%- endif -%}
      {%- if s.heading != blank -%}<h2 class="serena-h2">{{ s.heading }}</h2>{%- endif -%}
    </div>
    <div class="serena-why__grid">
      {%- for block in section.blocks -%}
        <div class="serena-why__card" {{ block.shopify_attributes }}>
          <span class="serena-why__ic">
            {%- if block.settings.icon != blank -%}
              {{ block.settings.icon | image_url: width: 64 | image_tag: loading: 'lazy', widths: '32, 64', alt: '' }}
            {%- else -%}
              <span class="serena-why__ring"></span>
            {%- endif -%}
          </span>
          <div>
            {%- if block.settings.title != blank -%}<div class="serena-why__t">{{ block.settings.title }}</div>{%- endif -%}
            {%- if block.settings.text != blank -%}<div class="serena-why__d">{{ block.settings.text }}</div>{%- endif -%}
          </div>
        </div>
      {%- endfor -%}
    </div>
  </div>
</div>

{% style %}
  #serena-why-{{ section.id }} { background: var(--bg); padding: var(--pt) 0 var(--pb); font-family: Mulish, sans-serif; }
  #serena-why-{{ section.id }} .serena-wrap { max-width: 1100px; margin: 0 auto; padding: 0 24px; }
  #serena-why-{{ section.id }} .serena-head { text-align: center; max-width: 640px; margin: 0 auto 44px; }
  #serena-why-{{ section.id }} .serena-eyebrow { font-size: 11.5px; letter-spacing: .2em; text-transform: uppercase; color: var(--eyebrow); font-weight: 800; }
  #serena-why-{{ section.id }} .serena-h2 { margin: 14px 0 0; font-family: Marcellus, serif; font-weight: 400; font-size: 34px; line-height: 1.18; color: #2C211B; }
  #serena-why-{{ section.id }} .serena-why__grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 18px; }
  #serena-why-{{ section.id }} .serena-why__card { display: flex; gap: 16px; background: var(--card-bg); border: 1px solid var(--card-border); border-radius: 18px; padding: 24px 22px; }
  #serena-why-{{ section.id }} .serena-why__ic { flex: none; width: 46px; height: 46px; border-radius: 50%; background: var(--ring-bg); display: flex; align-items: center; justify-content: center; overflow: hidden; }
  #serena-why-{{ section.id }} .serena-why__ic img { width: 22px; height: 22px; object-fit: contain; }
  #serena-why-{{ section.id }} .serena-why__ring { width: 16px; height: 16px; border: 2px solid var(--ring); border-radius: 50%; display: block; }
  #serena-why-{{ section.id }} .serena-why__t { font-weight: 800; font-size: 15.5px; color: #2C211B; }
  #serena-why-{{ section.id }} .serena-why__d { margin-top: 7px; font-size: 13px; line-height: 1.55; color: #7C6957; }
  @media (max-width: 990px) { #serena-why-{{ section.id }} .serena-why__grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 749px) {
    #serena-why-{{ section.id }} { padding: 56px 0; }
    #serena-why-{{ section.id }} .serena-head { margin-bottom: 30px; }
    #serena-why-{{ section.id }} .serena-h2 { font-size: 28px; }
    #serena-why-{{ section.id }} .serena-why__grid { grid-template-columns: 1fr; }
  }
  /* polish */
  #serena-why-{{ section.id }} .serena-why__card { box-shadow: 0 14px 34px -28px rgba(60,33,20,.3); transition: transform .25s ease, box-shadow .25s ease; }
  @media (hover: hover) { #serena-why-{{ section.id }} .serena-why__card:hover { transform: translateY(-3px); box-shadow: 0 24px 46px -28px rgba(60,33,20,.38); } }
  #serena-why-{{ section.id }} .serena-why__ring { width: 14px; height: 14px; background: var(--ring); border: none; box-shadow: 0 0 0 5px rgba(156,147,184,.18); }
  @media (max-width: 749px) { #serena-why-{{ section.id }} .serena-why__d { font-size: 13.5px; } }
{% endstyle %}

{% schema %}
{
  "name": "Serena · Защо",
  "tag": "section",
  "class": "serena-section",
  "settings": [
    { "type": "color", "id": "bg_color", "label": "Фон", "default": "#FBF5EC" },
    { "type": "color", "id": "eyebrow_color", "label": "Цвят на надтекста", "default": "#9C93B8" },
    { "type": "color", "id": "card_bg", "label": "Фон на картите", "default": "#F6EEF5" },
    { "type": "color", "id": "card_border", "label": "Рамка на картите", "default": "#E7DFEA" },
    { "type": "color", "id": "ring_bg", "label": "Фон на иконата", "default": "#ECE8F1" },
    { "type": "color", "id": "ring_color", "label": "Цвят на иконата", "default": "#9C93B8" },
    { "type": "text", "id": "eyebrow", "label": "Надтекст", "default": "Защо Serena Meno" },
    { "type": "text", "id": "heading", "label": "Заглавие", "default": "Създадена с грижа за този период от живота ти" },
    { "type": "header", "content": "Отстояние" },
    { "type": "range", "id": "padding_top", "min": 0, "max": 160, "step": 4, "unit": "px", "label": "Отстояние отгоре", "default": 84 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 160, "step": 4, "unit": "px", "label": "Отстояние отдолу", "default": 84 }
  ],
  "blocks": [
    {
      "type": "point",
      "name": "Точка на доверие",
      "settings": [
        { "type": "image_picker", "id": "icon", "label": "Икона (по избор)" },
        { "type": "text", "id": "title", "label": "Заглавие", "default": "Създадена за жени 40+" },
        { "type": "textarea", "id": "text", "label": "Описание", "default": "Съобразена с нуждите на тялото в този етап от живота." }
      ]
    }
  ],
  "presets": [
    {
      "name": "Serena · Защо",
      "blocks": [
        { "type": "point", "settings": { "title": "Създадена за жени 40+", "text": "Съобразена с нуждите на тялото в този етап от живота." } },
        { "type": "point", "settings": { "title": "Подходяща при перименопауза и менопауза", "text": "Подходяща за целия преходен период." } },
        { "type": "point", "settings": { "title": "Без хормони", "text": "Формула без хормони и без рецепта." } },
        { "type": "point", "settings": { "title": "Веган HPMC капсули", "text": "Растителни капсули, лесни за ежедневен прием." } },
        { "type": "point", "settings": { "title": "Лесен ежедневен прием", "text": "Две капсули на ден — нищо сложно." } },
        { "type": "point", "settings": { "title": "Част от 90-дневна wellness система", "text": "Създадена да те съпровожда месеци наред." } }
      ]
    }
  ]
}
{% endschema %}
