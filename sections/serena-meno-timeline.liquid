{%- comment -%} Serena Meno · Timeline — light card-based "what to expect" {%- endcomment -%}
{% render 'serena-meno-fonts' %}
{%- assign s = section.settings -%}
<div
  id="serena-tl-{{ section.id }}"
  class="serena-sec serena-tl"
  style="--bg: {{ s.bg_color }}; --eyebrow: {{ s.eyebrow_color }}; --heading: {{ s.heading_color }}; --pt: {{ s.padding_top }}px; --pb: {{ s.padding_bottom }}px;"
>
  <div class="serena-wrap">
    <div class="serena-tl__head">
      {%- if s.eyebrow != blank -%}<div class="serena-eyebrow">{{ s.eyebrow }}</div>{%- endif -%}
      {%- if s.heading != blank -%}<h2 class="serena-h2">{{ s.heading }}</h2>{%- endif -%}
      {%- if s.paragraph != blank -%}<p class="serena-tl__sub">{{ s.paragraph }}</p>{%- endif -%}
    </div>
    <div class="serena-tl__track">
      <div class="serena-tl__line" aria-hidden="true"></div>
      {%- for block in section.blocks -%}
        <div class="serena-tl__card" {{ block.shopify_attributes }}>
          <span class="serena-tl__dot">{{ block.settings.icon }}</span>
          <div class="serena-tl__row">
            {%- if block.settings.number != blank -%}<span class="serena-tl__num">{{ block.settings.number }}</span>{%- endif -%}
            {%- if block.settings.label != blank -%}<span class="serena-tl__w">{{ block.settings.label }}</span>{%- endif -%}
          </div>
          {%- if block.settings.text != blank -%}<div class="serena-tl__d">{{ block.settings.text }}</div>{%- endif -%}
        </div>
      {%- endfor -%}
    </div>
    {%- if s.disclaimer != blank -%}<div class="serena-tl__disc">{{ s.disclaimer }}</div>{%- endif -%}
  </div>
</div>

{% style %}
  #serena-tl-{{ section.id }} { background: var(--bg); padding: var(--pt) 0 var(--pb); font-family: Mulish, sans-serif; }
  #serena-tl-{{ section.id }} .serena-wrap { max-width: 620px; margin: 0 auto; padding: 0 24px; }
  #serena-tl-{{ section.id }} .serena-tl__head { text-align: center; margin: 0 auto 24px; }
  #serena-tl-{{ section.id }} .serena-eyebrow { font-size: 10.5px; letter-spacing: .2em; text-transform: uppercase; color: var(--eyebrow); font-weight: 800; }
  #serena-tl-{{ section.id }} .serena-h2 { margin: 11px 0 0; font-family: Marcellus, serif; font-weight: 400; font-size: 28px; line-height: 1.16; color: var(--heading); }
  #serena-tl-{{ section.id }} .serena-tl__sub { margin: 12px auto 0; font-size: 13px; line-height: 1.6; color: #7C6957; max-width: 320px; }
  #serena-tl-{{ section.id }} .serena-tl__track { position: relative; padding-left: 26px; }
  #serena-tl-{{ section.id }} .serena-tl__line { position: absolute; left: 13px; top: 14px; bottom: 14px; width: 2px; background: linear-gradient(180deg, #D8C3A6, #B98C6A, #8FA07C); }
  #serena-tl-{{ section.id }} .serena-tl__card { position: relative; background: #FFFCF6; border: 1px solid #ECDFCB; border-radius: 16px; padding: 15px 16px; box-shadow: 0 8px 20px -16px rgba(60,33,20,.4); margin-bottom: 12px; }
  #serena-tl-{{ section.id }} .serena-tl__card:last-child { margin-bottom: 0; }
  #serena-tl-{{ section.id }} .serena-tl__dot { position: absolute; left: -26px; top: 16px; width: 26px; height: 26px; border-radius: 50%; background: #FFFCF6; border: 1.5px solid #C99A6E; display: flex; align-items: center; justify-content: center; font-size: 13px; color: #B06A45; }
  #serena-tl-{{ section.id }} .serena-tl__row { display: flex; align-items: baseline; gap: 8px; }
  #serena-tl-{{ section.id }} .serena-tl__num { font-family: Marcellus, serif; font-size: 15px; color: #C09064; }
  #serena-tl-{{ section.id }} .serena-tl__w { font-weight: 800; font-size: 14px; color: #2C211B; }
  #serena-tl-{{ section.id }} .serena-tl__d { font-size: 12.5px; line-height: 1.55; color: #6F6353; margin-top: 6px; }
  #serena-tl-{{ section.id }} .serena-tl__disc { text-align: center; margin: 20px auto 0; font-size: 10.5px; color: #A2917C; line-height: 1.55; max-width: 560px; }
  @media (min-width: 750px) {
    #serena-tl-{{ section.id }} .serena-h2 { font-size: 32px; }
    #serena-tl-{{ section.id }} .serena-tl__d { font-size: 13px; }
  }
{% endstyle %}

{% schema %}
{
  "name": "Serena · Времева линия",
  "tag": "section",
  "class": "serena-section",
  "settings": [
    { "type": "color", "id": "bg_color", "label": "Фон", "default": "#F4ECDD" },
    { "type": "color", "id": "eyebrow_color", "label": "Цвят на надтекста", "default": "#B06A45" },
    { "type": "color", "id": "heading_color", "label": "Цвят на заглавието", "default": "#2C211B" },
    { "type": "text", "id": "eyebrow", "label": "Надтекст", "default": "Постепенна подкрепа" },
    { "type": "text", "id": "heading", "label": "Заглавие", "default": "Какво да очакваш през първите седмици" },
    { "type": "richtext", "id": "paragraph", "label": "Текст", "default": "<p>Serena Meno е създадена за ежедневна подкрепа. Най-добре се усеща като част от постоянна рутина — 2 капсули дневно, всеки ден.</p>" },
    { "type": "richtext", "id": "disclaimer", "label": "Бележка / disclaimer", "default": "<p>Резултатите са индивидуални и зависят от организма, начина на живот и постоянството на приема.</p>" },
    { "type": "header", "content": "Отстояние" },
    { "type": "range", "id": "padding_top", "min": 0, "max": 160, "step": 4, "unit": "px", "label": "Отстояние отгоре", "default": 56 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 160, "step": 4, "unit": "px", "label": "Отстояние отдолу", "default": 56 }
  ],
  "blocks": [
    {
      "type": "phase",
      "name": "Етап",
      "settings": [
        { "type": "text", "id": "number", "label": "Номер", "default": "01" },
        { "type": "text", "id": "icon", "label": "Икона (символ)", "default": "✦" },
        { "type": "text", "id": "label", "label": "Период", "default": "Първи дни" },
        { "type": "textarea", "id": "text", "label": "Описание", "default": "Започваш с 2 капсули дневно след хранене. Целта е тялото да получава постоянна подкрепа, а не еднократен ефект." }
      ]
    }
  ],
  "presets": [
    {
      "name": "Serena · Времева линия",
      "blocks": [
        { "type": "phase", "settings": { "number": "01", "icon": "✦", "label": "Първи дни", "text": "Започваш с 2 капсули дневно след хранене. Целта е тялото да получава постоянна подкрепа, а не еднократен ефект." } },
        { "type": "phase", "settings": { "number": "02", "icon": "☾", "label": "След 2 седмици", "text": "Много жени първо обръщат внимание на съня, спокойствието, енергията през деня или усещането за повече контрол в ежедневието." } },
        { "type": "phase", "settings": { "number": "03", "icon": "◔", "label": "След 30 дни", "text": "След първата опаковка вече можеш по-ясно да оцениш как Serena Meno се вписва в твоята рутина." } },
        { "type": "phase", "settings": { "number": "04", "icon": "❀", "label": "След 60–90 дни", "text": "Перименопаузата и менопаузата са процес, не момент. Затова постоянството и ежедневната грижа имат значение." } }
      ]
    }
  ]
}
{% endschema %}
