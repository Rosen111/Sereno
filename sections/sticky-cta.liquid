{% if section.settings.enable_custom_btn_color %}
  {% style %}
    #sticky-cta-{{ section.id }} .button {
      --color-button: {{ section.settings.custom_btn_color.red }}, {{ section.settings.custom_btn_color.green }}, {{ section.settings.custom_btn_color.blue }};
    }
  {% endstyle %}
{% endif %}

{%- liquid
  assign display_mode = section.settings.display_when
  assign display_threshold = 0
  if display_mode == 'after_pixels'
    assign display_threshold = section.settings.display_pixels
  elsif display_mode == 'after_percent'
    assign display_threshold = section.settings.display_percent
  endif
-%}

<sticky-atc
  id="sticky-cta-{{ section.id }}"
  class="sticky-atc sticky-cta color-{{ section.settings.color_scheme }}{% if section.settings.mobile_transparent_bg %} sticky-atc--mobile-transparent{% endif %}{% if section.settings.desktop_transparent_bg %} sticky-atc--desktop-transparent{% endif %}{% if section.settings.mobile_show_title %} sticky-atc--small-mobile-select{% endif %}"
  data-section="{{ section.id }}"
  data-display-mode="{{ display_mode }}"
  data-display-threshold="{{ display_threshold }}"
  {{ section.shopify_attributes }}
>
  <div class='sticky-atc-container page-width{% if section.settings.desktop_full_button_width %} sticky-atc--desktop-btn-full{% endif %}{% if section.settings.mobile_full_button_width %} sticky-atc--mobile-btn-full{% endif %}'>
    {%- if section.settings.image != blank and section.settings.mobile_show_image or section.settings.image != blank and section.settings.desktop_show_image -%}
      <div class='sticky-atc__image{% unless section.settings.mobile_show_image %} mobile-hidden{% endunless %}{% unless section.settings.desktop_show_image %} desktop-hidden{% endunless %}'>
        <img
          src="{{ section.settings.image | image_url: width: 500 }}"
          alt="{{ section.settings.image.alt | escape }}"
          loading="lazy"
          width="auto"
          height="auto"
        >
      </div>
    {%- endif -%}
    <div class='sticky-atc__left'>
      <div class='sticky-atc__left__content'>
        {% if section.settings.title != blank and section.settings.mobile_show_title or section.settings.title != blank and section.settings.desktop_show_title %}
          <h4 class='sticky-atc__title{% unless section.settings.mobile_show_title %} mobile-hidden{% endunless %}{% unless section.settings.desktop_show_title %} desktop-hidden{% endunless %}'>
            {{ section.settings.title }}
          </h4>
        {% endif %}
        {% if section.settings.mobile_rating_stars or section.settings.desktop_rating_stars %}
          <div class='rating-stars-and-text font-size--desktop-auto flex-center{% unless section.settings.mobile_rating_stars %} mobile-hidden{% endunless %}{% unless section.settings.desktop_rating_stars %} desktop-hidden{% endunless %}' style='--bg-star-color:{{ section.settings.star_color }};--font-size:1.3rem;--alignment:flex-start;'>
            <div class='rating-stars__container rating-stars__container--underlay'>
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 576 512" fill='currentColor'>
                <path d="M316.9 18C311.6 7 300.4 0 288.1 0s-23.4 7-28.8 18L195 150.3 51.4 171.5c-12 1.8-22 10.2-25.7 21.7s-.7 24.2 7.9 32.7L137.8 329 113.2 474.7c-2 12 3 24.2 12.9 31.3s23 8 33.8 2.3l128.3-68.5 128.3 68.5c10.8 5.7 23.9 4.9 33.8-2.3s14.9-19.3 12.9-31.3L438.5 329 542.7 225.9c8.6-8.5 11.7-21.2 7.9-32.7s-13.7-19.9-25.7-21.7L381.2 150.3 316.9 18z"/>
              </svg>
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 576 512" fill='currentColor'>
                <path d="M316.9 18C311.6 7 300.4 0 288.1 0s-23.4 7-28.8 18L195 150.3 51.4 171.5c-12 1.8-22 10.2-25.7 21.7s-.7 24.2 7.9 32.7L137.8 329 113.2 474.7c-2 12 3 24.2 12.9 31.3s23 8 33.8 2.3l128.3-68.5 128.3 68.5c10.8 5.7 23.9 4.9 33.8-2.3s14.9-19.3 12.9-31.3L438.5 329 542.7 225.9c8.6-8.5 11.7-21.2 7.9-32.7s-13.7-19.9-25.7-21.7L381.2 150.3 316.9 18z"/>
              </svg>
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 576 512" fill='currentColor'>
                <path d="M316.9 18C311.6 7 300.4 0 288.1 0s-23.4 7-28.8 18L195 150.3 51.4 171.5c-12 1.8-22 10.2-25.7 21.7s-.7 24.2 7.9 32.7L137.8 329 113.2 474.7c-2 12 3 24.2 12.9 31.3s23 8 33.8 2.3l128.3-68.5 128.3 68.5c10.8 5.7 23.9 4.9 33.8-2.3s14.9-19.3 12.9-31.3L438.5 329 542.7 225.9c8.6-8.5 11.7-21.2 7.9-32.7s-13.7-19.9-25.7-21.7L381.2 150.3 316.9 18z"/>
              </svg>
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 576 512" fill='currentColor'>
                <path d="M316.9 18C311.6 7 300.4 0 288.1 0s-23.4 7-28.8 18L195 150.3 51.4 171.5c-12 1.8-22 10.2-25.7 21.7s-.7 24.2 7.9 32.7L137.8 329 113.2 474.7c-2 12 3 24.2 12.9 31.3s23 8 33.8 2.3l128.3-68.5 128.3 68.5c10.8 5.7 23.9 4.9 33.8-2.3s14.9-19.3 12.9-31.3L438.5 329 542.7 225.9c8.6-8.5 11.7-21.2 7.9-32.7s-13.7-19.9-25.7-21.7L381.2 150.3 316.9 18z"/>
              </svg>
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 576 512" fill='currentColor'>
                <path d="M316.9 18C311.6 7 300.4 0 288.1 0s-23.4 7-28.8 18L195 150.3 51.4 171.5c-12 1.8-22 10.2-25.7 21.7s-.7 24.2 7.9 32.7L137.8 329 113.2 474.7c-2 12 3 24.2 12.9 31.3s23 8 33.8 2.3l128.3-68.5 128.3 68.5c10.8 5.7 23.9 4.9 33.8-2.3s14.9-19.3 12.9-31.3L438.5 329 542.7 225.9c8.6-8.5 11.7-21.2 7.9-32.7s-13.7-19.9-25.7-21.7L381.2 150.3 316.9 18z"/>
              </svg>
            </div>
            <span class="rating-stars__label">&nbsp;{{ section.settings.stars_label }}</span>
          </div>
        {% endif %}
        {%- if section.settings.subtitle != blank and section.settings.mobile_show_subtitle or section.settings.subtitle != blank and section.settings.desktop_show_subtitle -%}
          <div class='sticky-atc__price{% unless section.settings.mobile_show_subtitle %} mobile-hidden{% endunless %}{% unless section.settings.desktop_show_subtitle %} desktop-hidden{% endunless %}'>
            {{ section.settings.subtitle }}
          </div>
        {%- endif -%}
      </div>
    </div>
    <div class='sticky-atc__button'>
      {%- if section.settings.button_link != blank -%}
        <a
          class="sticky-atc__add_button button main-product-atc"
          href="{{ section.settings.button_link }}"
          {% if section.settings.open_in_new_tab %}target="_blank" rel="noopener"{% endif %}
        >
          <span class="sticky-atc__label">
            <span class="sticky-atc__label__text">{{ section.settings.button_label }}</span>
          </span>
        </a>
      {%- else -%}
        <button
          type="button"
          class="sticky-atc__add_button button main-product-atc"
          disabled
          aria-disabled="true"
        >
          <span class="sticky-atc__label">
            <span class="sticky-atc__label__text">{{ section.settings.button_label }}</span>
          </span>
        </button>
      {%- endif -%}
    </div>
  </div>
</sticky-atc>

{% schema %}
{
  "name": "Sticky CTA",
  "tag": "section",
  "settings": [
    {
      "type": "header",
      "content": "General"
    },
    {
      "type": "select",
      "id": "display_when",
      "label": "Display",
      "options": [
        { "value": "always", "label": "Always" },
        { "value": "after_pixels", "label": "After scrolling X pixels" },
        { "value": "after_percent", "label": "After scrolling X% of the page" }
      ],
      "default": "after_percent"
    },
    {
      "type": "range",
      "id": "display_pixels",
      "label": "Display after X pixels",
      "min": 50,
      "max": 2000,
      "step": 50,
      "unit": "px",
      "default": 500,
      "visible_if": "{{ section.settings.display_when == 'after_pixels' }}"
    },
    {
      "type": "range",
      "id": "display_percent",
      "label": "Display after X% of the page",
      "min": 5,
      "max": 95,
      "step": 5,
      "unit": "%",
      "default": 50,
      "visible_if": "{{ section.settings.display_when == 'after_percent' }}"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Sticky CTA title"
    },
    {
      "type": "inline_richtext",
      "id": "subtitle",
      "label": "Subtitle",
      "info": "Optional secondary line displayed under the title."
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "select",
      "id": "color_scheme",
      "options": [
        { "value": "accent-1", "label": "Accent 1" },
        { "value": "accent-2", "label": "Accent 2" },
        { "value": "background-1", "label": "Background 1" },
        { "value": "background-2", "label": "Background 2" },
        { "value": "inverse", "label": "Inverse" }
      ],
      "default": "background-1",
      "label": "Color scheme"
    },
    {
      "type": "color",
      "id": "star_color",
      "default": "#ffcc00",
      "label": "Rating stars color",
      "visible_if": "{{ section.settings.desktop_rating_stars or section.settings.mobile_rating_stars }}"
    },
    {
      "type": "inline_richtext",
      "id": "stars_label",
      "label": "Rating stars text",
      "default": "(xxxx Reviews)",
      "visible_if": "{{ section.settings.desktop_rating_stars or section.settings.mobile_rating_stars }}"
    },
    {
      "type": "header",
      "content": "Button"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Learn more"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "checkbox",
      "id": "open_in_new_tab",
      "label": "Open link in a new tab",
      "default": false,
      "visible_if": "{{ section.settings.button_link != blank }}"
    },
    {
      "type": "checkbox",
      "id": "enable_custom_btn_color",
      "label": "Enable custom button color",
      "default": false
    },
    {
      "type": "color",
      "id": "custom_btn_color",
      "default": "#dd1d1d",
      "label": "Button custom color",
      "visible_if": "{{ section.settings.enable_custom_btn_color }}"
    },
    {
      "type": "header",
      "content": "Desktop layout"
    },
    {
      "type": "checkbox",
      "id": "desktop_show_image",
      "default": false,
      "label": "Show image"
    },
    {
      "type": "checkbox",
      "id": "desktop_show_title",
      "default": true,
      "label": "Show title"
    },
    {
      "type": "checkbox",
      "id": "desktop_show_subtitle",
      "default": true,
      "label": "Show subtitle"
    },
    {
      "type": "checkbox",
      "id": "desktop_rating_stars",
      "default": false,
      "label": "Show rating stars"
    },
    {
      "type": "checkbox",
      "id": "desktop_full_button_width",
      "default": false,
      "label": "Button full width"
    },
    {
      "type": "checkbox",
      "id": "desktop_transparent_bg",
      "default": false,
      "label": "Use transparent background style.",
      "info": "This option automatically makes the button full width and hides all other elements."
    },
    {
      "type": "header",
      "content": "Mobile layout"
    },
    {
      "type": "checkbox",
      "id": "mobile_show_image",
      "default": false,
      "label": "Show image"
    },
    {
      "type": "checkbox",
      "id": "mobile_show_title",
      "default": true,
      "label": "Show title"
    },
    {
      "type": "checkbox",
      "id": "mobile_show_subtitle",
      "default": true,
      "label": "Show subtitle"
    },
    {
      "type": "checkbox",
      "id": "mobile_rating_stars",
      "default": false,
      "label": "Show rating stars"
    },
    {
      "type": "checkbox",
      "id": "mobile_full_button_width",
      "default": false,
      "label": "Button full width",
      "info": "Recommended if title and rating stars are disabled."
    },
    {
      "type": "checkbox",
      "id": "mobile_transparent_bg",
      "default": false,
      "label": "Use transparent background style.",
      "info": "This option automatically makes the button full width and hides all other elements."
    }
  ],
  "presets": [
    {
      "name": "Sticky CTA"
    }
  ]
}
{% endschema %}
