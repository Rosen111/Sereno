{%- comment -%} Serena Meno · CTA (layout: band = mid-page, final = dark centered) {%- endcomment -%}
{% render 'serena-meno-fonts' %}
{%- liquid
  assign s = section.settings
  assign link = s.button_link
  if link == blank
    assign link = '#'
  endif
-%}
<div
  id="serena-cta-{{ section.id }}"
  class="serena-sec serena-cta serena-cta--{{ s.layout }}"
  style="--bg: {{ s.bg_color }}; --accent: {{ s.accent_color }}; --accent-text: {{ s.accent_text_color }}; --heading-color: {{ s.heading_color }}; --pt: {{ s.padding_top }}px; --pb: {{ s.padding_bottom }}px;"
>
  {%- if s.layout == 'final' -%}
    <div class="serena-wrap serena-cta__final">
      {%- if s.eyebrow != blank -%}<div class="serena-eyebrow" style="color: var(--accent);">{{ s.eyebrow }}</div>{%- endif -%}
      {%- if s.heading != blank -%}<h2 class="serena-cta__h">{{ s.heading }}</h2>{%- endif -%}
      {%- if s.text != blank -%}<p class="serena-cta__p">{{ s.text }}</p>{%- endif -%}
      {%- if s.button_label != blank -%}<a class="serena-cta__btn" href="{{ link }}">{{ s.button_label }}</a>{%- endif -%}
      {%- if section.blocks.size > 0 -%}
        <div class="serena-cta__reassure">
          {%- for block in section.blocks -%}
            <div class="serena-cta__r" {{ block.shopify_attributes }}><span class="serena-cta__check">✓</span>{{ block.settings.label }}</div>
          {%- endfor -%}
        </div>
      {%- endif -%}
    </div>
  {%- else -%}
    <div class="serena-wrap serena-cta__band">
      <div>
        {%- if s.heading != blank -%}<div class="serena-cta__band-h">{{ s.heading }}</div>{%- endif -%}
        {%- if s.text != blank -%}<div class="serena-cta__band-sub">{{ s.text }}</div>{%- endif -%}
      </div>
      {%- if s.button_label != blank -%}<a class="serena-cta__band-btn" href="{{ link }}">{{ s.button_label }}</a>{%- endif -%}
    </div>
  {%- endif -%}
</div>

{% style %}
  #serena-cta-{{ section.id }} { background: var(--bg); padding: var(--pt) 0 var(--pb); font-family: Mulish, sans-serif; }
  #serena-cta-{{ section.id }} .serena-wrap { max-width: 1100px; margin: 0 auto; padding: 0 24px; }
  /* final */
  #serena-cta-{{ section.id }} .serena-cta__final { text-align: center; }
  #serena-cta-{{ section.id }} .serena-eyebrow { font-size: 11.5px; letter-spacing: .2em; text-transform: uppercase; font-weight: 800; }
  #serena-cta-{{ section.id }} .serena-cta__h { margin: 18px auto 0; font-family: Marcellus, serif; font-weight: 400; font-size: 40px; line-height: 1.16; color: var(--heading-color); max-width: 760px; }
  #serena-cta-{{ section.id }} .serena-cta__p { margin: 20px auto 0; font-size: 16px; line-height: 1.65; color: rgba(244, 236, 221, 0.92); max-width: 560px; }
  #serena-cta-{{ section.id }} .serena-cta__btn { display: inline-block; margin-top: 30px; background: var(--accent); color: var(--accent-text); text-decoration: none; font-weight: 800; font-size: 18px; padding: 20px 52px; border-radius: 14px; box-shadow: 0 18px 36px -16px rgba(189,85,50,.7); transition: filter .2s; }
  #serena-cta-{{ section.id }} .serena-cta__btn:hover { filter: brightness(0.92); }
  #serena-cta-{{ section.id }} .serena-cta__reassure { margin-top: 28px; display: flex; justify-content: center; gap: 28px; flex-wrap: wrap; }
  #serena-cta-{{ section.id }} .serena-cta__r { display: flex; align-items: center; gap: 9px; font-size: 13px; color: #ECE0CC; }
  #serena-cta-{{ section.id }} .serena-cta__check { width: 18px; height: 18px; border-radius: 50%; border: 1.5px solid #6B5340; display: flex; align-items: center; justify-content: center; font-size: 10px; color: var(--accent); }
  /* band */
  #serena-cta-{{ section.id }} .serena-cta__band { display: flex; align-items: center; justify-content: space-between; gap: 30px; flex-wrap: wrap; }
  #serena-cta-{{ section.id }} .serena-cta__band-h { font-family: Marcellus, serif; font-size: 25px; color: var(--heading-color); line-height: 1.25; }
  #serena-cta-{{ section.id }} .serena-cta__band-sub { font-size: 14px; color: #7C6957; margin-top: 8px; }
  #serena-cta-{{ section.id }} .serena-cta__band-btn { flex: none; border: 1.5px solid var(--accent); background: transparent; color: var(--accent); text-decoration: none; font-weight: 700; font-size: 15px; padding: 16px 38px; border-radius: 14px; transition: background .2s, color .2s; }
  #serena-cta-{{ section.id }} .serena-cta__band-btn:hover { background: var(--accent); color: var(--accent-text); }
  @media (max-width: 749px) {
    #serena-cta-{{ section.id }} .serena-cta__h { font-size: 30px; }
    #serena-cta-{{ section.id }} .serena-cta__band { gap: 18px; }
    #serena-cta-{{ section.id }} .serena-cta__band-btn { width: 100%; text-align: center; }
  }
  /* polish */
  #serena-cta-{{ section.id }} .serena-cta__btn { letter-spacing: .02em; min-width: 260px; }
  #serena-cta-{{ section.id }} .serena-cta__final { padding-top: 4px; padding-bottom: 4px; }
  #serena-cta-{{ section.id }} .serena-cta__reassure { margin-top: 32px; gap: 22px 34px; }
  @media (max-width: 749px) {
    #serena-cta-{{ section.id }} .serena-cta__h { font-size: 28px; }
    #serena-cta-{{ section.id }} .serena-cta__btn { min-width: 0; width: 100%; padding: 18px 32px; }
    #serena-cta-{{ section.id }} .serena-cta__reassure { gap: 14px 22px; }
    #serena-cta-{{ section.id }} .serena-cta__band-h { font-size: 22px; }
  }
{% endstyle %}

{% schema %}
{
  "name": "Serena · CTA",
  "tag": "section",
  "class": "serena-section",
  "settings": [
    { "type": "select", "id": "layout", "label": "Вид", "options": [ { "value": "band", "label": "Лента (среден CTA)" }, { "value": "final", "label": "Финален (тъмен, центриран)" } ], "default": "band" },
    { "type": "color", "id": "bg_color", "label": "Фон", "default": "#EFE3D2" },
    { "type": "color", "id": "heading_color", "label": "Цвят на заглавието", "default": "#2C211B" },
    { "type": "color", "id": "accent_color", "label": "Акцент (бутон)", "default": "#BD5532" },
    { "type": "color", "id": "accent_text_color", "label": "Текст на бутона (hover/плътен)", "default": "#FBF6EE" },
    { "type": "text", "id": "eyebrow", "label": "Надтекст (само финален)", "default": "Serena Meno" },
    { "type": "text", "id": "heading", "label": "Заглавие", "default": "Когато се почувстваш готова, ние сме тук." },
    { "type": "richtext", "id": "text", "label": "Подтекст" },
    { "type": "text", "id": "button_label", "label": "Текст на бутона", "default": "Поръчай Serena Meno" },
    { "type": "url", "id": "button_link", "label": "Линк на бутона" },
    { "type": "header", "content": "Отстояние" },
    { "type": "range", "id": "padding_top", "min": 0, "max": 160, "step": 4, "unit": "px", "label": "Отстояние отгоре", "default": 44 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 160, "step": 4, "unit": "px", "label": "Отстояние отдолу", "default": 44 }
  ],
  "blocks": [
    {
      "type": "reassurance",
      "name": "Уверение (само финален)",
      "settings": [
        { "type": "text", "id": "label", "label": "Текст", "default": "Бърза доставка" }
      ]
    }
  ],
  "presets": [
    { "name": "Serena · CTA (лента)", "settings": { "layout": "band", "bg_color": "#EFE3D2" } },
    { "name": "Serena · CTA (финален)", "settings": { "layout": "final", "bg_color": "#2C211B", "heading_color": "#F4ECDD", "heading": "Върни усещането за спокойствие, баланс и контрол в ежедневието си." } }
  ]
}
{% endschema %}
