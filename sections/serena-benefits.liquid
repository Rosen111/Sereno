{%- comment -%} Serena Meno · 2. Benefits cards {%- endcomment -%}
{% render 'serena-meno-fonts' %}
{%- assign s = section.settings -%}
<div
  id="serena-benefits-{{ section.id }}"
  class="serena-sec serena-benefits"
  style="--bg: {{ s.bg_color }}; --eyebrow: {{ s.eyebrow_color }}; --pt: {{ s.padding_top }}px; --pb: {{ s.padding_bottom }}px;"
>
  <div class="serena-wrap">
    <div class="serena-head">
      {%- if s.eyebrow != blank -%}<div class="serena-eyebrow">{{ s.eyebrow }}</div>{%- endif -%}
      {%- if s.heading != blank -%}<h2 class="serena-h2 serena-h2--center">{{ s.heading }}</h2>{%- endif -%}
      {%- if s.subheading != blank -%}<p class="serena-benefits__subhead">{{ s.subheading }}</p>{%- endif -%}
    </div>
    <div class="serena-benefits__grid">
      {%- for block in section.blocks -%}
        <div class="serena-card" {{ block.shopify_attributes }}>
          <span class="serena-card__ic">
            {%- if block.settings.icon != blank -%}
              {{ block.settings.icon | image_url: width: 80 | image_tag: loading: 'lazy', widths: '40, 80', alt: '' }}
            {%- elsif block.settings.icon_emoji != blank -%}
              <span class="serena-card__emoji">{{ block.settings.icon_emoji }}</span>
            {%- else -%}
              <span class="serena-card__ring"></span>
            {%- endif -%}
          </span>
          {%- if block.settings.title != blank -%}<div class="serena-card__t">{{ block.settings.title }}</div>{%- endif -%}
          {%- if block.settings.text != blank -%}<div class="serena-card__d">{{ block.settings.text }}</div>{%- endif -%}
        </div>
      {%- endfor -%}
      {%- if s.tile_image != blank -%}
        <div class="serena-benefits__tile">
          {{ s.tile_image | image_url: width: 700 | image_tag: loading: 'lazy', sizes: '(max-width: 749px) 50vw, 220px', widths: '300, 500, 700', alt: '' }}
          {%- if s.tile_caption != blank -%}<div class="serena-benefits__tile-cap">{{ s.tile_caption }}</div>{%- endif -%}
        </div>
      {%- endif -%}
    </div>
  </div>
</div>

{% style %}
  #serena-benefits-{{ section.id }} { background: var(--bg); padding: var(--pt) 0 var(--pb); font-family: Mulish, sans-serif; }
  #serena-benefits-{{ section.id }} .serena-wrap { max-width: 1100px; margin: 0 auto; padding: 0 24px; }
  #serena-benefits-{{ section.id }} .serena-head { text-align: center; max-width: 680px; margin: 0 auto 44px; }
  #serena-benefits-{{ section.id }} .serena-eyebrow { font-size: 11.5px; letter-spacing: .2em; text-transform: uppercase; color: var(--eyebrow); font-weight: 800; }
  #serena-benefits-{{ section.id }} .serena-h2 { margin: 14px 0 0; font-family: Marcellus, serif; font-weight: 400; font-size: 34px; line-height: 1.18; color: #2C211B; }
  #serena-benefits-{{ section.id }} .serena-benefits__grid { display: grid; grid-template-columns: repeat(5, 1fr); gap: 16px; }
  #serena-benefits-{{ section.id }} .serena-card { background: #FFFDF8; border: 1px solid #ECDFCB; border-radius: 18px; padding: 26px 20px; }
  #serena-benefits-{{ section.id }} .serena-card__ic { width: 50px; height: 50px; border-radius: 50%; background: #F4E6E2; display: flex; align-items: center; justify-content: center; overflow: hidden; }
  #serena-benefits-{{ section.id }} .serena-card__ic img { width: 26px; height: 26px; object-fit: contain; }
  #serena-benefits-{{ section.id }} .serena-card__ring { width: 19px; height: 19px; border: 2px solid #C58B86; border-radius: 50%; display: block; }
  #serena-benefits-{{ section.id }} .serena-card__t { margin-top: 18px; font-weight: 800; font-size: 15px; line-height: 1.3; color: #2C211B; }
  #serena-benefits-{{ section.id }} .serena-card__d { margin-top: 9px; font-size: 13px; line-height: 1.5; color: #7C6957; }
  @media (max-width: 990px) { #serena-benefits-{{ section.id }} .serena-benefits__grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 749px) {
    #serena-benefits-{{ section.id }} { padding: 56px 0; }
    #serena-benefits-{{ section.id }} .serena-head { margin-bottom: 30px; }
    #serena-benefits-{{ section.id }} .serena-h2 { font-size: 28px; }
    #serena-benefits-{{ section.id }} .serena-benefits__grid { grid-template-columns: 1fr; gap: 12px; }
  }
  /* polish */
  #serena-benefits-{{ section.id }} .serena-card { box-shadow: 0 14px 34px -26px rgba(60,33,20,.35); transition: transform .25s ease, box-shadow .25s ease; }
  @media (hover: hover) { #serena-benefits-{{ section.id }} .serena-card:hover { transform: translateY(-3px); box-shadow: 0 24px 46px -26px rgba(60,33,20,.42); } }
  #serena-benefits-{{ section.id }} .serena-card__ring { width: 14px; height: 14px; background: #C58B86; border: none; box-shadow: 0 0 0 5px rgba(197,139,134,.18); }
  @media (max-width: 749px) { #serena-benefits-{{ section.id }} .serena-card__d { font-size: 13.5px; } }
{% endstyle %}

{% schema %}
{
  "name": "Serena · Ползи",
  "tag": "section",
  "class": "serena-section",
  "settings": [
    { "type": "color", "id": "bg_color", "label": "Фон", "default": "#F6EAE6" },
    { "type": "color", "id": "eyebrow_color", "label": "Цвят на надтекста", "default": "#C07A6A" },
    { "type": "text", "id": "eyebrow", "label": "Надтекст", "default": "Ползи" },
    { "type": "text", "id": "heading", "label": "Заглавие", "default": "Ползи от Serena Meno" },
    { "type": "textarea", "id": "subheading", "label": "Подзаглавие (курсив)", "default": "Не за да „поправиш“ себе си — а за да се усещаш малко повече като себе си, всеки ден." },
    { "type": "header", "content": "Снимка-плочка (по избор)" },
    { "type": "image_picker", "id": "tile_image", "label": "Изображение" },
    { "type": "text", "id": "tile_caption", "label": "Надпис върху снимката", "default": "Създадена за теб, в този период." },
    { "type": "header", "content": "Отстояние" },
    { "type": "range", "id": "padding_top", "min": 0, "max": 160, "step": 4, "unit": "px", "label": "Отстояние отгоре", "default": 84 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 160, "step": 4, "unit": "px", "label": "Отстояние отдолу", "default": 84 }
  ],
  "blocks": [
    {
      "type": "benefit",
      "name": "Карта с полза",
      "settings": [
        { "type": "text", "id": "icon_emoji", "label": "Икона (емоджи/символ)", "default": "❀" },
        { "type": "image_picker", "id": "icon", "label": "Икона-изображение (по избор)" },
        { "type": "text", "id": "title", "label": "Заглавие", "default": "Подкрепа при горещи вълни" },
        { "type": "textarea", "id": "text", "label": "Описание", "default": "Създадена да подпомага тялото ти в моментите на внезапна топлина и дискомфорт." }
      ]
    }
  ],
  "presets": [
    {
      "name": "Serena · Ползи",
      "blocks": [
        { "type": "benefit", "settings": { "title": "Подкрепа при горещи вълни", "text": "Създадена да подпомага тялото ти в моментите на внезапна топлина и дискомфорт." } },
        { "type": "benefit", "settings": { "title": "Подкрепа за по-спокоен сън", "text": "Подкрепя спокойна вечерна рутина за по-пълноценна почивка." } },
        { "type": "benefit", "settings": { "title": "Подкрепа за баланс в настроението", "text": "Допринася за усещане за вътрешно спокойствие през деня." } },
        { "type": "benefit", "settings": { "title": "Подкрепа за повече ежедневен комфорт", "text": "Създадена като нежна ежедневна подкрепа за тялото ти." } },
        { "type": "benefit", "settings": { "title": "Подкрепа за жени 40+", "text": "Натурални съставки, подбрани за периода на промяна." } }
      ]
    }
  ]
}
{% endschema %}
