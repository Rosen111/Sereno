{%- comment -%} Serena Meno · 7. Ingredients — dark photo-slider with doses {%- endcomment -%}
{% render 'serena-meno-fonts' %}
{%- assign s = section.settings -%}
<div
  id="serena-ing-{{ section.id }}"
  class="serena-sec serena-ing"
  style="--bg: {{ s.bg_color }}; --eyebrow: {{ s.eyebrow_color }}; --pt: {{ s.padding_top }}px; --pb: {{ s.padding_bottom }}px;"
>
  <div class="serena-ing__head">
    {%- if s.eyebrow != blank -%}<div class="serena-eyebrow">{{ s.eyebrow }}</div>{%- endif -%}
    {%- if s.heading != blank -%}<h2 class="serena-h2">{{ s.heading }}</h2>{%- endif -%}
    {%- if s.paragraph != blank -%}<p class="serena-ing__sub">{{ s.paragraph }}</p>{%- endif -%}
  </div>
  <div class="serena-ing__slider" id="serena-ing-scroll-{{ section.id }}">
    {%- for block in section.blocks -%}
      <div class="serena-ing__card" {{ block.shopify_attributes }}>
        <div class="serena-ing__cardbody">
          {%- if block.settings.name != blank -%}<div class="serena-ing__n">{{ block.settings.name }}</div>{%- endif -%}
          {%- if block.settings.text != blank -%}<p class="serena-ing__d">{{ block.settings.text }}</p>{%- endif -%}
          {%- if block.settings.dose != blank -%}<div class="serena-ing__dose">{{ block.settings.dose }}</div>{%- endif -%}
        </div>
        {%- if block.settings.image != blank -%}
          {{ block.settings.image | image_url: width: 500 | image_tag: loading: 'lazy', sizes: '160px', widths: '200, 320, 500', class: 'serena-ing__img' }}
        {%- else -%}
          <div class="serena-ing__img serena-ing__ph" aria-hidden="true"><span>{{ block.settings.name }}</span></div>
        {%- endif -%}
      </div>
    {%- endfor -%}
  </div>
  {%- if section.blocks.size > 1 -%}
    <div class="serena-ing__dots">
      {%- for block in section.blocks -%}
        <span class="serena-ing__dot{% if forloop.first %} is-active{% endif %}"></span>
      {%- endfor -%}
    </div>
  {%- endif -%}
</div>

<script>
  (function () {
    var sl = document.getElementById('serena-ing-scroll-{{ section.id }}');
    var wrap = document.getElementById('serena-ing-{{ section.id }}');
    if (!sl || !wrap) return;
    var dots = wrap.querySelectorAll('.serena-ing__dot');
    if (!dots.length) return;
    function upd() {
      var first = sl.children[0];
      if (!first) return;
      var step = first.offsetWidth + 13;
      var i = Math.round(sl.scrollLeft / step);
      if (i < 0) i = 0; if (i > dots.length - 1) i = dots.length - 1;
      for (var d = 0; d < dots.length; d++) dots[d].classList.toggle('is-active', d === i);
    }
    sl.addEventListener('scroll', function () { window.requestAnimationFrame(upd); }, { passive: true });
  })();
</script>

{% style %}
  #serena-ing-{{ section.id }} { background: var(--bg); padding: var(--pt) 0 var(--pb); font-family: Mulish, sans-serif; }
  #serena-ing-{{ section.id }} .serena-ing__head { text-align: center; max-width: 640px; margin: 0 auto 6px; padding: 0 24px; }
  #serena-ing-{{ section.id }} .serena-eyebrow { font-size: 11px; letter-spacing: .2em; text-transform: uppercase; color: var(--eyebrow); font-weight: 800; }
  #serena-ing-{{ section.id }} .serena-h2 { margin: 11px 0 0; font-family: Marcellus, serif; font-weight: 400; font-size: 30px; line-height: 1.18; color: #2C211B; }
  #serena-ing-{{ section.id }} .serena-ing__sub { margin: 10px auto 0; font-size: 13px; line-height: 1.55; color: #7C6957; max-width: 320px; }
  #serena-ing-{{ section.id }} .serena-ing__slider { display: flex; gap: 13px; overflow-x: auto; scroll-snap-type: x mandatory; -webkit-overflow-scrolling: touch; padding: 18px 24px 6px; scrollbar-width: none; }
  #serena-ing-{{ section.id }} .serena-ing__slider::-webkit-scrollbar { height: 0; display: none; }
  #serena-ing-{{ section.id }} .serena-ing__card { flex: 0 0 80%; scroll-snap-align: center; display: flex; background: #2E4034; border-radius: 18px; overflow: hidden; min-height: 188px; box-shadow: 0 16px 34px -22px rgba(28,30,22,.7); }
  #serena-ing-{{ section.id }} .serena-ing__cardbody { flex: 1; min-width: 0; padding: 18px 16px; display: flex; flex-direction: column; }
  #serena-ing-{{ section.id }} .serena-ing__n { font-weight: 800; font-size: 16px; color: #FBF7EF; line-height: 1.12; }
  #serena-ing-{{ section.id }} .serena-ing__d { margin: 9px 0 0; font-size: 11.5px; line-height: 1.45; color: #C7D2C2; flex: 1; }
  #serena-ing-{{ section.id }} .serena-ing__dose { margin-top: 10px; font-weight: 800; font-size: 19px; color: #FBF7EF; }
  #serena-ing-{{ section.id }} .serena-ing__img { flex: none; width: 42%; align-self: stretch; object-fit: cover; }
  #serena-ing-{{ section.id }} .serena-ing__ph { display: flex; align-items: center; justify-content: center; text-align: center; padding: 8px; background: linear-gradient(150deg, #3A4E40, #2E4034); }
  #serena-ing-{{ section.id }} .serena-ing__ph span { font-family: Marcellus, serif; font-size: 13px; color: #A9BBA6; line-height: 1.2; }
  #serena-ing-{{ section.id }} .serena-ing__dots { display: flex; justify-content: center; gap: 5px; flex-wrap: wrap; margin-top: 16px; padding: 0 40px; }
  #serena-ing-{{ section.id }} .serena-ing__dot { width: 6px; height: 6px; border-radius: 999px; background: #D6C0A8; transition: all .2s ease; }
  #serena-ing-{{ section.id }} .serena-ing__dot.is-active { width: 18px; background: #BD5532; }
  @media (min-width: 750px) {
    #serena-ing-{{ section.id }} .serena-h2 { font-size: 34px; }
    #serena-ing-{{ section.id }} .serena-ing__slider { padding-left: max(24px, calc((100% - 1100px) / 2)); padding-right: max(24px, calc((100% - 1100px) / 2)); }
    #serena-ing-{{ section.id }} .serena-ing__card { flex: 0 0 340px; }
  }
{% endstyle %}

{% schema %}
{
  "name": "Serena · Съставки",
  "tag": "section",
  "class": "serena-section",
  "settings": [
    { "type": "color", "id": "bg_color", "label": "Фон", "default": "#EFE3D2" },
    { "type": "color", "id": "eyebrow_color", "label": "Цвят на надтекста", "default": "#B06A45" },
    { "type": "text", "id": "eyebrow", "label": "Надтекст", "default": "Формулата" },
    { "type": "text", "id": "heading", "label": "Заглавие", "default": "Внимателно подбрани съставки" },
    { "type": "richtext", "id": "paragraph", "label": "Текст", "default": "<p>Растителни екстракти, витамини и минерали, подбрани за ежедневна подкрепа в периода на перименопауза и менопауза.</p>" },
    { "type": "header", "content": "Отстояние" },
    { "type": "range", "id": "padding_top", "min": 0, "max": 160, "step": 4, "unit": "px", "label": "Отстояние отгоре", "default": 56 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 160, "step": 4, "unit": "px", "label": "Отстояние отдолу", "default": 56 }
  ],
  "blocks": [
    {
      "type": "ingredient",
      "name": "Съставка",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Снимка" },
        { "type": "text", "id": "name", "label": "Име", "default": "Ашваганда KSM-66®" },
        { "type": "text", "id": "dose", "label": "Доза", "default": "300 mg" },
        { "type": "text", "id": "tag", "label": "Латинско име (по избор)", "default": "" },
        { "type": "textarea", "id": "text", "label": "Описание", "default": "Подбрана да подпомага усещането за спокойствие и устойчивост при ежедневен стрес." }
      ]
    }
  ],
  "presets": [
    {
      "name": "Serena · Съставки",
      "blocks": [
        { "type": "ingredient", "settings": { "name": "Ашваганда KSM-66®", "dose": "300 mg", "text": "Подбрана да подпомага усещането за спокойствие и устойчивост при ежедневен стрес." } },
        { "type": "ingredient", "settings": { "name": "Шафран Affron®", "dose": "30 mg", "text": "Подбран да подпомага емоционалния баланс и по-спокойното ежедневие." } },
        { "type": "ingredient", "settings": { "name": "Градински чай", "dose": "300 mg", "text": "Подбран за подкрепа при усещане за топлинен дискомфорт." } },
        { "type": "ingredient", "settings": { "name": "Serenzo™", "dose": "30 mg", "text": "Цитрусов екстракт, включен за усещане за спокойствие." } },
        { "type": "ingredient", "settings": { "name": "Червена детелина", "dose": "100 mg", "text": "Традиционно свързвана с подкрепа в периода на перименопауза и менопауза." } },
        { "type": "ingredient", "settings": { "name": "Джинджифил", "dose": "50 mg", "text": "Подпомага храносмилателния комфорт." } },
        { "type": "ingredient", "settings": { "name": "Магнезий бисглицинат", "dose": "100 mg", "text": "Допринася за нервната система и за намаляване на умората." } },
        { "type": "ingredient", "settings": { "name": "Витамин D3", "dose": "50 mcg", "text": "Допринася за поддържането на нормални кости и нормалната имунна функция." } },
        { "type": "ingredient", "settings": { "name": "Витамин K2 MK-7", "dose": "75 mcg", "text": "Допринася за поддържането на нормални кости." } },
        { "type": "ingredient", "settings": { "name": "Цинк", "dose": "10 mg", "text": "Принос към коса, кожа, нокти и нормален метаболизъм." } },
        { "type": "ingredient", "settings": { "name": "Витамин B6", "dose": "5 mg", "text": "Допринася за регулиране на хормоналната активност." } },
        { "type": "ingredient", "settings": { "name": "Витамин B12", "dose": "25 mcg", "text": "Допринася за намаляване на умората и отпадналостта." } }
      ]
    }
  ]
}
{% endschema %}
