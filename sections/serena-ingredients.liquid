{%- comment -%} Serena Meno · 7. Ingredients / formula {%- endcomment -%}
{% render 'serena-meno-fonts' %}
{%- assign s = section.settings -%}
<div
  id="serena-ing-{{ section.id }}"
  class="serena-sec serena-ing"
  style="--bg: {{ s.bg_color }}; --eyebrow: {{ s.eyebrow_color }}; --ring-bg: {{ s.ring_bg }}; --ring: {{ s.ring_color }}; --pt: {{ s.padding_top }}px; --pb: {{ s.padding_bottom }}px;"
>
  <div class="serena-wrap">
    <div class="serena-head">
      {%- if s.eyebrow != blank -%}<div class="serena-eyebrow">{{ s.eyebrow }}</div>{%- endif -%}
      {%- if s.heading != blank -%}<h2 class="serena-h2">{{ s.heading }}</h2>{%- endif -%}
      {%- if s.paragraph != blank -%}<p class="serena-sub">{{ s.paragraph }}</p>{%- endif -%}
    </div>
    <div class="serena-ing__grid">
      {%- for block in section.blocks -%}
        <div class="serena-ing__card" {{ block.shopify_attributes }}>
          <div class="serena-ing__row">
            {%- if block.settings.name != blank -%}<span class="serena-ing__n">{{ block.settings.name }}</span>{%- endif -%}
            {%- if block.settings.dose != blank -%}<span class="serena-ing__dose">{{ block.settings.dose }}</span>{%- endif -%}
          </div>
          {%- if block.settings.tag != blank -%}<div class="serena-ing__tag">{{ block.settings.tag }}</div>{%- endif -%}
          {%- if block.settings.text != blank -%}<div class="serena-ing__d">{{ block.settings.text }}</div>{%- endif -%}
        </div>
      {%- endfor -%}
    </div>
  </div>
</div>

{% style %}
  #serena-ing-{{ section.id }} { background: var(--bg); padding: var(--pt) 0 var(--pb); font-family: Mulish, sans-serif; }
  #serena-ing-{{ section.id }} .serena-wrap { max-width: 1100px; margin: 0 auto; padding: 0 24px; }
  #serena-ing-{{ section.id }} .serena-head { text-align: center; max-width: 680px; margin: 0 auto 46px; }
  #serena-ing-{{ section.id }} .serena-eyebrow { font-size: 11.5px; letter-spacing: .2em; text-transform: uppercase; color: var(--eyebrow); font-weight: 800; }
  #serena-ing-{{ section.id }} .serena-h2 { margin: 14px 0 0; font-family: Marcellus, serif; font-weight: 400; font-size: 34px; line-height: 1.18; color: #2C211B; }
  #serena-ing-{{ section.id }} .serena-sub { margin: 14px auto 0; font-size: 15px; line-height: 1.65; color: #7C6957; max-width: 560px; }
  #serena-ing-{{ section.id }} .serena-ing__grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 18px; }
  #serena-ing-{{ section.id }} .serena-ing__card { background: #FFFDF8; border: 1px solid #ECDFCB; border-radius: 18px; padding: 28px 26px; }
  #serena-ing-{{ section.id }} .serena-ing__top { display: flex; align-items: center; gap: 14px; }
  #serena-ing-{{ section.id }} .serena-ing__ic { flex: none; width: 48px; height: 48px; border-radius: 50%; background: var(--ring-bg); display: flex; align-items: center; justify-content: center; overflow: hidden; }
  #serena-ing-{{ section.id }} .serena-ing__ic img { width: 22px; height: 22px; object-fit: contain; }
  #serena-ing-{{ section.id }} .serena-ing__ring { width: 16px; height: 16px; border: 2px solid var(--ring); border-radius: 50%; display: block; }
  #serena-ing-{{ section.id }} .serena-ing__n { font-family: Marcellus, serif; font-size: 19px; color: #2C211B; line-height: 1.1; }
  #serena-ing-{{ section.id }} .serena-ing__tag { font-size: 10.5px; letter-spacing: .08em; text-transform: uppercase; color: #A8927C; font-style: italic; margin-top: 4px; }
  #serena-ing-{{ section.id }} .serena-ing__d { margin-top: 16px; font-size: 13.5px; line-height: 1.6; color: #6B5B4E; }
  @media (max-width: 990px) { #serena-ing-{{ section.id }} .serena-ing__grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 749px) {
    #serena-ing-{{ section.id }} { padding: 56px 0; }
    #serena-ing-{{ section.id }} .serena-head { margin-bottom: 30px; }
    #serena-ing-{{ section.id }} .serena-h2 { font-size: 28px; }
    #serena-ing-{{ section.id }} .serena-ing__grid { grid-template-columns: 1fr; gap: 14px; }
  }
  /* polish */
  #serena-ing-{{ section.id }} .serena-ing__card { box-shadow: 0 14px 34px -26px rgba(60,33,20,.32); transition: transform .25s ease, box-shadow .25s ease; }
  @media (hover: hover) { #serena-ing-{{ section.id }} .serena-ing__card:hover { transform: translateY(-3px); box-shadow: 0 24px 46px -26px rgba(60,33,20,.4); } }
  #serena-ing-{{ section.id }} .serena-ing__ring { width: 14px; height: 14px; background: var(--ring); border: none; box-shadow: 0 0 0 5px rgba(116,128,95,.16); }
  @media (max-width: 749px) { #serena-ing-{{ section.id }} .serena-ing__d { font-size: 13.5px; } }
{% endstyle %}

{% schema %}
{
  "name": "Serena · Съставки",
  "tag": "section",
  "class": "serena-section",
  "settings": [
    { "type": "color", "id": "bg_color", "label": "Фон", "default": "#FBF5EC" },
    { "type": "color", "id": "eyebrow_color", "label": "Цвят на надтекста", "default": "#B06A45" },
    { "type": "color", "id": "ring_bg", "label": "Фон на иконата", "default": "#EAEADD" },
    { "type": "color", "id": "ring_color", "label": "Цвят на иконата", "default": "#74805F" },
    { "type": "text", "id": "eyebrow", "label": "Надтекст", "default": "Формулата" },
    { "type": "text", "id": "heading", "label": "Заглавие", "default": "Внимателно подбрани съставки, създадени да подкрепят" },
    { "type": "richtext", "id": "paragraph", "label": "Текст", "default": "<p>Всяка съставка е избрана заради ролята си в подкрепата на жените през перименопауза и менопауза.</p>" },
    { "type": "header", "content": "Отстояние" },
    { "type": "range", "id": "padding_top", "min": 0, "max": 160, "step": 4, "unit": "px", "label": "Отстояние отгоре", "default": 84 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 160, "step": 4, "unit": "px", "label": "Отстояние отдолу", "default": 84 }
  ],
  "blocks": [
    {
      "type": "ingredient",
      "name": "Съставка",
      "settings": [
        { "type": "text", "id": "name", "label": "Име", "default": "Ашваганда KSM-66®" },
        { "type": "text", "id": "dose", "label": "Доза", "default": "300 mg" },
        { "type": "text", "id": "tag", "label": "Латинско име", "default": "Withania somnifera" },
        { "type": "textarea", "id": "text", "label": "Описание", "default": "Адаптоген, който допринася за устойчивост при ежедневно напрежение." }
      ]
    }
  ],
  "presets": [
    {
      "name": "Serena · Съставки",
      "blocks": [
        { "type": "ingredient", "settings": { "name": "Ашваганда KSM-66®", "tag": "Withania somnifera · 300 mg", "text": "Адаптоген, който допринася за устойчивост при ежедневно напрежение." } },
        { "type": "ingredient", "settings": { "name": "Шафран affron®", "tag": "Crocus sativus · 30 mg", "text": "Подбран да подпомага усещането за спокойствие и баланс на настроението." } },
        { "type": "ingredient", "settings": { "name": "Червена детелина", "tag": "Trifolium pratense · 100 mg", "text": "Растителен екстракт, традиционно свързван с подкрепа за жени в периода на менопауза." } },
        { "type": "ingredient", "settings": { "name": "Магнезий бисглицинат", "tag": "Magnesium · 100 mg", "text": "Допринася за нормалната функция на нервната система и за намаляване на умората." } },
        { "type": "ingredient", "settings": { "name": "Витамин D3", "tag": "Vitamin D3 · 2000 IU", "text": "Допринася за поддържане на нормални кости и нормална имунна функция." } },
        { "type": "ingredient", "settings": { "name": "Витамин B6 (P-5-P)", "tag": "Vitamin B6 · 5 mg", "text": "Допринася за регулиране на хормоналната активност в организма." } }
      ]
    }
  ]
}
{% endschema %}
